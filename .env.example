APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000

# Leave these empty for local demo mode.
# Fill all three values to enable Supabase Auth, Storage, and task history.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=face-processing
SUPABASE_ORIGINAL_BUCKET=aifx-originals
SUPABASE_CROP_BUCKET=aifx-crops
SUPABASE_ENHANCED_CROP_BUCKET=aifx-enhanced-crops
SUPABASE_ENHANCED_ORIGINAL_BUCKET=aifx-enhanced-originals

# Phase 2 worker and private ComfyUI connection.
COMFYUI_URL=http://127.0.0.1:8189
COMFYUI_TIMEOUT_SECONDS=300
AIFX_PHASE2_API_KEYS=
AIFX_WORKER_API_KEY=
AIFX_WORKER_POLL_SECONDS=2
